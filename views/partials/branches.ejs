<section class="branches">
  <div class="branch-glow"></div>
  <div class="container">
    <!-- SECTION HEADER -->
    <div class="section-header branch-animate">
      <h2>London Branches</h2>
      <p>Visit our stores across London</p>
    </div>

    <!-- GRID -->
    <div class="branches-grid">
      <!-- CARD -->
      <div class="branch-card branch-animate">
        <div class="branch-icon">
          <i class="fa-solid fa-location-dot"></i>
        </div>
        <h3>Camden Town</h3>
        <p>Open 9:00 AM – 11:00 PM</p>
        <button class="map-btn" data-map="camden">View Map</button>
      </div>

      <div class="branch-card branch-animate">
        <div class="branch-icon">
          <i class="fa-solid fa-location-dot"></i>
        </div>
        <h3>Oxford Street</h3>
        <p>Open 9:00 AM – 11:00 PM</p>
        <button class="map-btn" data-map="oxford">View Map</button>
      </div>

      <div class="branch-card branch-animate">
        <div class="branch-icon">
          <i class="fa-solid fa-location-dot"></i>
        </div>
        <h3>Edgware Road</h3>
        <p>Open 10:00 AM – 10:00 PM</p>
        <button class="map-btn" data-map="edgware">View Map</button>
      </div>

      <div class="branch-card branch-animate">
        <div class="branch-icon">
          <i class="fa-solid fa-location-dot"></i>
        </div>
        <h3>Southall</h3>
        <p>Coming Soon</p>
        <button class="map-btn disabled">Coming Soon</button>
      </div>
    </div>
  </div>
</section>

<!-- MAP MODAL -->
<div class="map-modal" id="mapModal">
  <div class="map-content">
    <span class="close-map" id="closeMap">&times;</span>
    <iframe id="mapFrame" src="" loading="lazy"></iframe>
  </div>
</div>
