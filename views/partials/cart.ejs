<!-- ===== CART OVERLAY ===== -->
<div class="cart-overlay"></div>

<!-- ===== CART SIDEBAR ===== -->
<div class="cart">
  <!-- HEADER -->
  <div class="cart-header">
    <h3>YOUR BAG&nbsp;(<span id="cart-count">0</span>)</h3>
    <i class="fa-solid fa-xmark close-cart"></i>
  </div>

  <hr />

  <!-- ITEMS -->
  <div class="cart-items"></div>

  <hr />

  <!-- FOOTER -->
  <div class="cart-footer">
    <div class="subtotal">
      <span>Subtotal</span>
      <span id="subtotal">£0.00</span>
    </div>

    <a href="/checkout">
      <button class="checkout-btn">
        <i class="fa-solid fa-lock"></i>&nbsp;SECURE CHECKOUT
      </button>
    </a>
  </div>
</div>
