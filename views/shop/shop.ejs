<section class="shop">
  <h2 class="shop-title">Shop Collection</h2>
  <p class="shop-sub">Premium snus products</p>

  <!-- FILTERS -->
  
<div class="filters">

  <!-- ALL -->
  <button id="resetFilters" class="filter-btn active">All</button>

  <!-- BRANDS -->
  <div class="dropdown">
    <button class="filter-btn dropdown-toggle">
      Brands <i class="fa-solid fa-chevron-down"></i>
    </button>

    <div class="dropdown-menu">
      <a class="filter-item" data-filter="brand" data-value="white fox">WHITE FOX</a>
      <a class="filter-item" data-filter="brand" data-value="siberia">SIBERIA</a>
      <a class="filter-item" data-filter="brand" data-value="velo">VELO</a>
      <a class="filter-item" data-filter="brand" data-value="killa">KILLA</a>
      <a class="filter-item" data-filter="brand" data-value="pablo">PABLO</a>
      <a class="filter-item" data-filter="brand" data-value="garant">GARANT</a>
      <a class="filter-item" data-filter="brand" data-value="iceberg cuba">ICEBERG CUBA</a>
      <a class="filter-item" data-filter="brand" data-value="loop">LOOP</a>
      <a class="filter-item" data-filter="brand" data-value="cafero">CAFERO</a>
      <a class="filter-item" data-filter="brand" data-value="hit">HIT</a>
      <a class="filter-item" data-filter="brand" data-value="oden's">ODEN'S</a>
    </div>
  </div>

  <!-- STRENGTH -->
  <div class="dropdown">
    <button class="filter-btn dropdown-toggle">
      Strength <i class="fa-solid fa-chevron-down"></i>
    </button>

    <div class="dropdown-menu">
      <a class="filter-item" data-filter="strength" data-value="LOW">LOW</a>
      <a class="filter-item" data-filter="strength" data-value="MEDIUM">MEDIUM</a>
      <a class="filter-item" data-filter="strength" data-value="STRONG">STRONG</a>
      <a class="filter-item" data-filter="strength" data-value="X-STRONG">X-STRONG</a>
      <a class="filter-item" data-filter="strength" data-value="EXTREME">EXTREME</a>
    </div>
  </div>

  <!-- FLAVOURS -->
  <div class="dropdown">
    <button class="filter-btn dropdown-toggle">
      Flavours <i class="fa-solid fa-chevron-down"></i>
    </button>

    <div class="dropdown-menu">
      <a class="filter-item" data-filter="flavour" data-value="minty mood">MINTY MOOD</a>
      <a class="filter-item" data-filter="flavour" data-value="fruity fantasy">FRUITY FANTASY</a>
      <a class="filter-item" data-filter="flavour" data-value="cittus cyclone">CITRUS CYCLONE</a>
      <a class="filter-item" data-filter="flavour" data-value="fizzy fun">FIZZY FUN</a>
    </div>
  </div>

</div>

    <div class="products">
       <% products.forEach(p => { %>
    <a href="/products/<%= p._id %>" class="link-card">
      <div class="card">

        <!-- LABEL -->
        <span class="label"><%= p.strength || 'NORMAL' %></span>

        <!-- IMAGE -->
        <img src="<%= p.images[0] %>" />

        <!-- NAME -->
        <h4><%= p.name %></h4>

        <!-- DESC -->
        <p class="desc">
          <%= p.description.substring(0, 60) %>...
        </p>

        <!-- META -->
        <p class="meta">
          <%= p.strength %> • <%= p.nicotine || '0mg' %>mg
        </p>

        <!-- PRICE -->
        <div class="bottom">
          <span class="price">£<%= p.price.toFixed(2) %></span>

          <button class="cart-btn">
            <i class="fa-solid fa-cart-shopping"></i>
          </button>
        </div>

      </div>
    </a>

  <% }) %>

</div>


  <button class="load-more">Load More</button>
</section>


<script>
let page = 1;
let filters = {};

const container = document.querySelector(".products");
const loadBtn = document.getElementById("loadMore");

//FILTER CLICK 
document.querySelectorAll(".filter-item").forEach(item => {
  item.addEventListener("click", async () => {

    const type = item.dataset.filter;
    const value = item.dataset.value;

    filters[type] = value;
    page = 1;

    await loadProducts(true);
  });
});

//RESET 
document.getElementById("resetFilters").addEventListener("click", async () => {
  filters = {};
  page = 1;
  await loadProducts(true);
});

//  LOAD MORE 
loadBtn.addEventListener("click", async () => {
  page++;
  await loadProducts();
});

//FETCH FUNCTION 
async function loadProducts(reset = false) {

  const params = new URLSearchParams(filters);
  params.set("page", page);

  const res = await fetch("/shop?" + params.toString(), {
    headers: { "Accept": "application/json" }
  });

  const data = await res.json();

  if (reset) {
    container.innerHTML = "";
  }

  data.products.forEach(p => {
    const card = `
      <a href="/products/${p._id}" class="link-card">
        <div class="card">

          <span class="label">${p.strength || 'NORMAL'}</span>

          <img src="${p.images?.[0] || ''}" />

          <h4>${p.name}</h4>

          <p class="desc">
            ${(p.description || '').substring(0, 60)}...
          </p>

          <p class="meta">
            ${p.strength || ''} • ${p.nicotine || '0'}mg
          </p>

          <div class="bottom">
            <span class="price">£${p.price}</span>
            <button class="cart-btn">
              <i class="fa-solid fa-cart-shopping"></i>
            </button>
          </div>

        </div>
      </a>
    `;

    container.insertAdjacentHTML("beforeend", card);
  });

  // hide load more
  if (!data.hasMore) {
    loadBtn.style.display = "none";
  } else {
    loadBtn.style.display = "block";
  }

  //  update URL (PRO level)
  window.history.pushState({}, "", "/shop?" + params.toString());
}
</script>
