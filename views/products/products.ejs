<section class="product-page">
  <!-- LEFT (IMAGE) -->
  <div class="product-gallery">
    <div class="main-image">
      <img id="mainProductImg" src="/images/shop/sb-1.png" />
    </div>

    <div class="thumbnails">
      <img class="thumb active" src="/images/shop/sb-1.png" />
      <img class="thumb" src="/images/shop/wf-1.png" />
      <img class="thumb" src="/images/shop/velo-1.webp" />
    </div>
  </div>

  <!-- RIGHT (INFO) -->
  <div class="product-info">
    <h1 class="product-title">Siberia -80°C</h1>

    <!-- ⭐ RATING -->
    <div class="rating">
      ★★★★☆
      <span>(4.0)</span>
    </div>

    <p class="product-desc">
      One of the strongest nicotine pouches with icy mint hit and long-lasting
      freshness.
    </p>

    <div class="product-meta">
      <span><b>Brand:</b> Siberia</span>
      <span><b>Strength:</b> Extreme</span>
      <span><b>Nicotine:</b> 25mg</span>
      <span><b>Flavour:</b> Mint</span>
    </div>

    <div class="price-box">
      <span class="price">£6.49</span>
      <span class="stock">In Stock</span>
    </div>

    <!-- CART -->
    <div class="cart-section">
      <button type="button" class="add-cart">
        <i class="fa-solid fa-cart-shopping"></i>&nbsp; Add to Cart
      </button>
    </div>
  </div>
</section>

<!-- TABS -->
<section class="product-extra">
  <div class="tabs">
    <button class="tab active" data-tab="desc">Description</button>
    <button class="tab" data-tab="details">Details</button>
    <button class="tab" data-tab="reviews">Reviews</button>
  </div>

  <div class="tab-content active" id="desc">
    <p>
      This premium product delivers a powerful nicotine experience with intense
      cooling mint.
    </p>
  </div>

  <div class="tab-content" id="details">
    <p>Nicotine: 25mg | Brand: Siberia | Flavour: Mint</p>
  </div>

  <div class="tab-content" id="reviews">
    <p>No reviews yet.</p>
  </div>
</section>

